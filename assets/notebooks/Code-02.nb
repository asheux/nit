Cell[BoxData[{
 RowBox[{"ClearAll", "[", "WinnersByMatch", "]"}], "\n", 
 RowBox[{
  RowBox[{"WinnersByMatch", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"prog1_String", ",", "prog2_String"}], "}"}], ",", 
    "pairtotals_Association"}], "]"}], ":=", 
  RowBox[{"Association", "[", 
   RowBox[{"KeyValueMap", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"p1", "=", 
           RowBox[{"#1", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", 
          RowBox[{"p2", "=", 
           RowBox[{"#1", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", 
          RowBox[{"m", "=", 
           RowBox[{"Subtract", "@@", "#2"}]}]}], "}"}], ",", 
        RowBox[{"#1", "->", 
         RowBox[{"Which", "[", 
          RowBox[{
           RowBox[{"m", ">", "0"}], ",", 
           RowBox[{
            RowBox[{"player", "[", "prog1", "]"}], "[", "p1", "]"}], ",", 
           RowBox[{"m", "<", "0"}], ",", 
           RowBox[{
            RowBox[{"player", "[", "prog2", "]"}], "[", "p2", "]"}], ",", 
           "True", ",", 
           RowBox[{"Missing", "[", "\"\<Tie\>\"", "]"}]}], "]"}]}]}], "]"}], 
      "&"}], ",", "pairtotals"}], "]"}], "]"}]}], "\n"}], "Input",

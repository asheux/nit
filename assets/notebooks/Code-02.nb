              RowBox[{"evalone", "/@", "#"}], ")"}], "&"}], ",", "chunks", ",", 
            RowBox[{"Method", "->", "\"\<CoarsestGrained\>\""}]}], "]"}]}]}], 
        ",", 
        RowBox[{"evalone", "/@", "idx"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 

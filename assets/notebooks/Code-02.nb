Cell[BoxData[
 RowBox[{
  RowBox[{"CanonicalKeyMap", "[", 
   RowBox[{"key_", ",", 
    RowBox[{"k_Integer", "?", "Positive"}], ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"len", "=", 
       RowBox[{"Quotient", "[", 
        RowBox[{
         RowBox[{"Length", "[", "key", "]"}], ",", 
         RowBox[{"k", "+", "1"}]}], "]"}]}], ",", "act", ",", "tgt"}], "}"}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"act", "=", 
      RowBox[{"Take", "[", 
       RowBox[{"key", ",", "len"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"tgt", "=", 
      RowBox[{"Partition", "[", 
       RowBox[{
        RowBox[{"Drop", "[", 
         RowBox[{"key", ",", "len"}], "]"}], ",", "k"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Flatten", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"If", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"OptionValue", "[", "\"\<Return\>\"", "]"}], 
           "===", "\"\<Rules\>\""}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"u", ",", "m"}], "}"}], "->", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"tgt", "[", 
              RowBox[{"[", 
               RowBox[{"u", ",", 
                RowBox[{"m", "+", "1"}]}], "]"}], "]"}], ",", 
             RowBox[{"act", "[", 
              RowBox[{"[", "u", "]"}], "]"}]}], "}"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"u", ",", "m", ",", 
            RowBox[{"tgt", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", 
               RowBox[{"m", "+", "1"}]}], "]"}], "]"}], ",", 
            RowBox[{"act", "[", 
             RowBox[{"[", "u", "]"}], "]"}]}], "}"}]}], "\[IndentingNewLine]",
          "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"u", ",", "len"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"m", ",", "0", ",", 
          RowBox[{"k", "-", "1"}]}], "}"}]}], "]"}], "\[IndentingNewLine]", 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",

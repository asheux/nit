     RowBox[{"\"\<ReturnDataset\>\"", "->", "True"}]}], "\[IndentingNewLine]",
     "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ScanGameWinnersSlow", "[", 
   RowBox[{
   "games_List", ",", "pairs_List", ",", "outcomecounts_Association", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"labels", "=", 
       RowBox[{"OptionValue", "[", "\"\<ProgramLabels\>\"", "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"shape", "=", 
       RowBox[{"OptionValue", "[", "\"\<MachineShape\>\"", "]"}]}], ",", 
      "build", ",", "out", ",", "\[IndentingNewLine]", 
      RowBox[{"par", "=", 
       RowBox[{"OptionValue", "[", "\"\<Parallel\>\"", "]"}]}]}], 
     "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"build", "[", "gi_", "]"}], ":=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "g", ",", "totalso", ",", "totalsu", ",", "sb", ",", "winnerrow", ",",
           "winner"}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"g", "=", 
          RowBox[{"games", "[", 
           RowBox[{"[", "gi", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"totalso", "=", 
          RowBox[{"PairTotalsFromOutcomeCounts", "[", 
           RowBox[{"outcomecounts", ",", "g"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"totalsu", "=", 
          RowBox[{"AssociationMap", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Function", "[", 
             RowBox[{"p", ",", "\[IndentingNewLine]", 
              RowBox[{"With", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"s12", "=", 
                   RowBox[{"Lookup", "[", 
                    RowBox[{"totalso", ",", 
                    RowBox[{"Key", "[", "p", "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "0"}], "}"}]}], "]"}]}], ",", 
                  RowBox[{"s21", "=", 
                   RowBox[{"Lookup", "[", 
                    RowBox[{"totalso", ",", 
                    RowBox[{"Key", "[", 
                    RowBox[{"Reverse", "[", "p", "]"}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "0"}], "}"}]}], "]"}]}]}], "}"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"Mean", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"s12", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], ",", 
                    RowBox[{"s21", "[", 
                    RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "]"}], ",", 
                  RowBox[{"Mean", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"s12", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], ",", 
                    RowBox[{"s21", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], "}"}], "]"}]}], "}"}]}],
                "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], 
            ",", "pairs"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"sb", "=", 
          RowBox[{"TournamentScoreboard", "[", 
           RowBox[{"labels", ",", "totalsu"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"winnerrow", "=", 
          RowBox[{"First", "[", 
           RowBox[{"Normal", "[", "sb", "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"winner", "=", 
          RowBox[{"winnerrow", "[", "\"\<ID\>\"", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"<|", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"\"\<GameIndex\>\"", "->", "gi"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"\"\<Winner\>\"", "->", "winner"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"\"\<WinnerAvgPayoff\>\"", "->", 

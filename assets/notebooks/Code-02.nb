Cell[BoxData[{
 RowBox[{"ClearAll", "[", "StrategyGraph", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "StrategyGraph", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<ShowLabels\>\"", "->", "False"}], ",", 
     RowBox[{"ImageSize", "->", "Automatic"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"StrategyGraph", "[", 
   RowBox[{"rule_List", ",", 
    RowBox[{"init_", ":", "Automatic"}], ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "g0", ",", "g", ",", "pos", ",", "initv", ",", "bounds", ",", "scale"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"rule", "===", "$Failed"}], ",", 
       RowBox[{"Return", "[", "rule", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"g0", "=", 
      RowBox[{"Graph", "[", 
       RowBox[{
        RowBox[{"Union", "[", 
         RowBox[{
          RowBox[{"rule", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1", ",", "1"}], "]"}], "]"}], ",", 
          RowBox[{"rule", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "2", ",", "1"}], "]"}], "]"}]}], "]"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "/.", " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"ms_", ",", "oi_"}], "}"}], "->", 
              RowBox[{"{", 
               RowBox[{"ns_", ",", "a_"}], "}"}]}], ")"}], ":>", 
            RowBox[{"DirectedEdge", "[", 
             RowBox[{"ms", ",", "ns", ",", "oi"}], "]"}]}]}], "&"}], "/@", 
         "rule"}], ",", "opts"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"initv", "=", 
      RowBox[{"Replace", "[", 
       RowBox[{"init", ",", 
        RowBox[{"Automatic", "->", 
         RowBox[{"First", "@", 
          RowBox[{"VertexList", "[", "g0", "]"}]}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"initv", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ListQ", "[", "initv", "]"}], "&&", 
         RowBox[{
          RowBox[{"Length", "[", "initv", "]"}], "==", "1"}]}], ",", 
        RowBox[{"First", "[", "initv", "]"}], ",", "initv"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"g", "=", 
      RowBox[{"Subgraph", "[", 
       RowBox[{"g0", ",", 
        RowBox[{"VertexOutComponent", "[", 
         RowBox[{"g0", ",", "initv"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pos", "=", 
      RowBox[{"AssociationThread", "[", 
       RowBox[{
        RowBox[{"VertexList", "[", "g", "]"}], ",", 
        RowBox[{"GraphEmbedding", "[", "g", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"bounds", "=", 
      RowBox[{"CoordinateBounds", "[", 
       RowBox[{"Values", "[", "pos", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"scale", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "bounds", "]"}], ">=", "2"}], ",", 
        RowBox[{"Max", "[", 
         RowBox[{"1", ",", 
          RowBox[{
           RowBox[{"bounds", "[", 
            RowBox[{"[", 
             RowBox[{"2", ",", "2"}], "]"}], "]"}], "-", 
           RowBox[{"bounds", "[", 
            RowBox[{"[", 
             RowBox[{"2", ",", "1"}], "]"}], "]"}]}]}], "]"}], ",", "1"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"g", "=", 
      RowBox[{"Graph", "[", 
       RowBox[{
        RowBox[{"VertexList", "[", "g", "]"}], ",", 
        RowBox[{"EdgeList", "[", "g", "]"}], ",", 
        RowBox[{"EdgeLabels", "->", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"TrueQ", "[", 
            RowBox[{"OptionValue", "[", "\"\<ShowLabels\>\"", "]"}], "]"}], ",", 
           RowBox[{"e_", ":>", 
            RowBox[{"Placed", "[", 
             RowBox[{
              RowBox[{"Framed", "[", 
               RowBox[{
                RowBox[{"e", "[", 
                 RowBox[{"[", "3", "]"}], "]"}], ",", 
                RowBox[{"FrameMargins", "->", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"4", ",", "4"}], "}"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"2", ",", "2"}], "}"}]}], "}"}]}], ",", 
                RowBox[{"Background", "->", "White"}]}], "]"}], ",", 
              "Center"}], "]"}]}], ",", "None"}], "]"}]}], ",", 
        RowBox[{"VertexLabels", "->", "Automatic"}], ",", 
        RowBox[{"VertexShapeFunction", "->", "\"\<Square\>\""}], ",", 
        RowBox[{"VertexSize", "->", 
         RowBox[{"0.03", " ", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"Length", "[", "rule", "]"}], "]"}]}]}], ",", 
        RowBox[{"VertexStyle", "->", 
         RowBox[{"Normal", "[", 
          RowBox[{"KeyTake", "[", 
           RowBox[{
            RowBox[{"KeyValueMap", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"#1", "->", 
                RowBox[{"Replace", "[", 
                 RowBox[{"#2", ",", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"0", "->", "Green"}], ",", 
                    RowBox[{"1", "->", "Red"}], ",", 
                    RowBox[{"_", "->", "Green"}]}], "}"}]}], "]"}]}], "&"}], ",", 
              RowBox[{"Association", "[", 
               RowBox[{"Rule", "@@@", 
                RowBox[{"Last", "/@", "rule"}]}], "]"}]}], "]"}], ",", 
            RowBox[{"VertexList", "[", "g", "]"}]}], "]"}], "]"}]}], ",", 
        RowBox[{"EdgeStyle", "->", 
         RowBox[{"e_", ":>", 
          RowBox[{"Directive", "[", 
           RowBox[{"Thick", ",", 
            RowBox[{"Replace", "[", 
             RowBox[{
              RowBox[{"e", "[", 
               RowBox[{"[", "3", "]"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"0", "->", "Green"}], ",", 
                RowBox[{"1", "->", "Red"}], ",", 
                RowBox[{"_", "->", "Black"}]}], "}"}]}], "]"}]}], "]"}]}]}], ",", 
        RowBox[{"VertexLabelStyle", "->", 
         RowBox[{"Directive", "[", 
          RowBox[{"Black", ",", "Bold"}], "]"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Show", "[", 
      RowBox[{"g", ",", 
       RowBox[{"Epilog", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"AbsoluteThickness", "[", "1", "]"}], ",", 
          RowBox[{"Arrowheads", "[", 
           RowBox[{"0.04", "*", "scale"}], "]"}], ",", 
          RowBox[{"Arrow", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"pos", "[", "initv", "]"}], "+", 

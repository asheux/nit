 RowBox[{
  RowBox[{"ScoreWithTimeouts", "[", 
   RowBox[{"gamematrix_", ",", "outcome_", ",", "haltedflags_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"lose", ",", "win", ",", "base", ",", "vals", ",", "hf"}], "}"}],
     ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"vals", "=", 
      RowBox[{"Flatten", "[", "gamematrix", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"lose", ",", "win"}], "}"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Min", "[", "vals", "]"}], ",", 
        RowBox[{"Max", "[", "vals", "]"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"lose", "==", "win"}], "&&", 
        RowBox[{"lose", ">", "0"}]}], ",", 
       RowBox[{"lose", "=", "0"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lose", "==", "win"}], "&&", 
          RowBox[{"lose", "<=", "0"}]}], ",", 
         RowBox[{"lose", "=", 
          RowBox[{"lose", "-", "1"}]}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"base", "=", 
      RowBox[{"Score", "[", 
       RowBox[{"gamematrix", ",", "outcome"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"hf", "=", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"ConstantArray", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"True", ",", "True"}], "}"}], ",", 
          RowBox[{
           RowBox[{"Length", "[", "base", "]"}], "-", 
           RowBox[{"Length", "[", "haltedflags", "]"}]}]}], "]"}], ",", 
        "haltedflags"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"MapThread", "[", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"pay", ",", "h"}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Which", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"h", "===", 
            RowBox[{"{", 
             RowBox[{"True", ",", "True"}], "}"}]}], ",", "pay", ",", 
           "\[IndentingNewLine]", 
           RowBox[{"h", "===", 
            RowBox[{"{", 
             RowBox[{"False", ",", "True"}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"lose", ",", "win"}], "}"}], ",", "\[IndentingNewLine]", 
           RowBox[{"h", "===", 
            RowBox[{"{", 
             RowBox[{"True", ",", "False"}], "}"}]}], ",", 

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "FindTransientRepeatMachines", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "FindTransientRepeatMachines", "]"}], "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\"\<Seed\>\"", "->", "42"}], ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<Rounds\>\"", "->", "10"}], ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<InitHistory\>\"", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<TransientRepeatDepth\>\"", "->", "3"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<ReturnHaltingFlags\>\"", "->", "False"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<Player\>\"", "->", "1"}]}], "\[IndentingNewLine]", "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FindTransientRepeatMachines", "[", 
   RowBox[{"strat_", ",", 
    RowBox[{"maxindex_Integer", "?", "Positive"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"start_Integer", "?", "NonNegative"}], ",", 
      RowBox[{"end_Integer", "?", "NonNegative"}]}], "}"}], ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"seed", ",", 
      RowBox[{"showhalts", "=", 
       RowBox[{"OptionValue", "[", "\"\<ReturnHaltingFlags\>\"", "]"}]}]}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"seed", "=", 
      RowBox[{"OptionValue", "[", "\"\<Seed\>\"", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"ParallelTable", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"SeedRandom", "[", 
           RowBox[{"seed", " ", "+", " ", "i"}], "]"}], ";", 
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"repeat", ",", 
              RowBox[{"machine", "=", 
               RowBox[{"RandomInteger", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"0", ",", " ", "maxindex"}], "}"}], ",", " ", "2"}],
                 "]"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"repeat", "=", 
              RowBox[{"Last", "[", 
               RowBox[{"FindTransientRepeat", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{"With", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"hist", "=", 
                    RowBox[{"IteratedGame", "[", 
                    RowBox[{
                    RowBox[{"strat", "/@", " ", "#"}], ",", " ", 
                    RowBox[{"OptionValue", "[", "\"\<InitHistory\>\"", "]"}], 
                    ",", " ", 
                    RowBox[{"OptionValue", "[", "\"\<Rounds\>\"", "]"}], ",", 
                    
                    
                    RowBox[{"\"\<ReturnHaltingFlags\>\"", "->", 
                    "showhalts"}]}], "]"}]}], "}"}], ",", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"TrueQ", "[", "showhalts", "]"}], ",", 
                    RowBox[{"First", "[", "hist", "]"}], ",", "hist"}], 
                    "]"}]}], "]"}], "&"}], "[", "machine", "]"}], ",", " ", 
                 RowBox[{
                 "OptionValue", "[", "\"\<TransientRepeatDepth\>\"", "]"}]}], 
                "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Length", "[", "repeat", "]"}], "==", "0"}], ",", 
               "machine", ",", "Infinity"}], "]"}]}]}], "\[IndentingNewLine]",
            "]"}]}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"i", ",", " ", "start", ",", "end"}], "}"}]}], "]"}], ",", 
       RowBox[{"FreeQ", "[", "Infinity", "]"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]}], "Input",

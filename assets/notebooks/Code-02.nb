Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "TransientPeriodHeatmap", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TransientPeriodHeatmap", "[", "tp_List", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"maxt", ",", "maxp", ",", "mint", ",", "minp"}], "}"}], ",", 

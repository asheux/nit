Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "CanonicalContractionData", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"CanonicalContractionData", "[", 
   RowBox[{"items_List", ",", "keyfn_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"classes", ",", "repmap"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"classes", "=", 
      RowBox[{"GroupBy", "[", 
       RowBox[{"items", ",", "keyfn"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"repmap", "=", 
      RowBox[{"Association", "[", 
       RowBox[{"Flatten", "[", 
        RowBox[{"KeyValueMap", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Thread", "[", 
            RowBox[{"#2", "->", 
             RowBox[{"First", "[", "#2", "]"}]}], "]"}], "&"}], ",", 
          "classes"}], "]"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"<|", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\"\<Items\>\"", "->", "items"}], ",", "\[IndentingNewLine]", 
       RowBox[{"\"\<Classes\>\"", "->", "classes"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<RepresentativeByItem\>\"", "->", "repmap"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<Representatives\>\"", "->", 
        RowBox[{"Sort", "[", 
         RowBox[{"DeleteDuplicates", "[", 
          RowBox[{"Values", "[", "repmap", "]"}], "]"}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<ClassSizes\>\"", "->", 
        RowBox[{"(", 
         RowBox[{"Length", "/@", 
          RowBox[{"Values", "[", "classes", "]"}]}], ")"}]}]}], 
      "\[IndentingNewLine]", "|>"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.981117188323135*^9, 3.9811172426929502`*^9}},
 CellLabel->
  "In[240]:=",ExpressionUUID->"12247268-de47-423c-b635-a4fd1c38ee21"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "ClassSizeHistogramPlot", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ClassSizeHistogramPlot", "[", "data_Association", "]"}], ":=", 
  RowBox[{"Histogram", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"data", "[", "\"\<ClassSizes\>\"", "]"}], ",", "Automatic", 

              RowBox[{"All", ",", "All", ",", "2"}], "]"}], "]"}]}], "]"}]}], 
         ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"toVec", "[", "x_", "]"}], ":=", 

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "LeaderboardBarChart", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "LeaderboardBarChart", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"ImageSize", "->", "Automatic"}], ",", 
     RowBox[{"\"\<ShowPlotLabel\>\"", "->", "True"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"LeaderboardBarChart", "[", 
   RowBox[{"pairtotals_", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"winners", ",", "wincounts"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"winners", "=", 
      RowBox[{"KeyValueMap", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Which", "[", 
          RowBox[{
           RowBox[{"#2", ">", "0"}], ",", 
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", 
           RowBox[{"#2", "<", "0"}], ",", 
           RowBox[{"#1", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", "True", ",", 
           RowBox[{"Missing", "[", "\"\<Tie\>\"", "]"}]}], "]"}], "&"}], ",", 
        
        RowBox[{
         RowBox[{
          RowBox[{"Subtract", "@@", "#"}], "&"}], "/@", "pairtotals"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"wincounts", "=", 
      RowBox[{"ReverseSort", "[", 
       RowBox[{"Counts", "[", 
        RowBox[{"DeleteMissing", "[", "winners", "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"BarChart", "[", 
      RowBox[{"wincounts", ",", "\[IndentingNewLine]", 
       RowBox[{"ChartLabels", "->", 
        RowBox[{"Placed", "[", 
         RowBox[{
          RowBox[{"Keys", "[", "wincounts", "]"}], ",", "Axis", ",", 
          RowBox[{
           RowBox[{"Rotate", "[", 
            RowBox[{"#", ",", 
             RowBox[{"Pi", "/", "4"}]}], "]"}], "&"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"OptionValue", "[", "\"\<ShowPlotLabel\>\"", "]"}], 
          ",", "\"\<Top machine by match wins (Total payoff)\>\"", ",", 
          "None"}], "]"}]}], ",", 
       RowBox[{"AxesLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<Machine\>\"", ",", "\"\<Win counts\>\""}], "}"}]}], ",",
        "\[IndentingNewLine]", 
       RowBox[{"ImageSize", "->", 
        RowBox[{"OptionValue", "[", "ImageSize", "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"AspectRatio", "->", 
        RowBox[{"1", "/", "2"}]}]}], "\[IndentingNewLine]", "]"}]}]}], 

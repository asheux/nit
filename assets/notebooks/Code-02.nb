Cell[BoxData[{
 RowBox[{"ClearAll", "[", "TournamentScores", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "TournamentScores", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<Aggregator\>\"", "->", "Total"}], ",", 
     RowBox[{"\"\<InitialHistory\>\"", "->", 
      RowBox[{"{", "}"}]}], ",", 
     RowBox[{"\"\<ReturnHaltingFlags\>\"", "->", "False"}], ",", " ", 
     RowBox[{"\"\<Parallel\>\"", "->", "True"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TournamentScores", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"b1_", ",", "b2_"}], "}"}], ",", "pairs_", ",", "game_", ",", 
    "rounds_", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"aggregator", "=", 
       RowBox[{"OptionValue", "[", "\"\<Aggregator\>\"", "]"}]}], ",", 
      "grouped", ",", "scored"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"grouped", "=", 
      RowBox[{"GroupBy", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"OptionValue", "[", "\"\<Parallel\>\"", "]"}], ",", " ", 
           "ParallelMap", ",", " ", "Map"}], "]"}], "[", 
         RowBox[{
          RowBox[{"Function", "[", 
           RowBox[{"p", ",", "\[IndentingNewLine]", 
            RowBox[{"p", "->", 
             RowBox[{"IteratedGame", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"b1", "[", 
                  RowBox[{"p", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
                 RowBox[{"b2", "[", 
                  RowBox[{"p", "[", 
                   RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "}"}], ",", 
               RowBox[{"OptionValue", "[", "\"\<InitialHistory\>\"", "]"}], ",",
                "rounds", ",", 
               RowBox[{"\"\<ReturnHaltingFlags\>\"", "->", 
                RowBox[{
                "OptionValue", "[", "\"\<ReturnHaltingFlags\>\"", "]"}]}]}], 
              "]"}]}]}], "\[IndentingNewLine]", "]"}], ",", "pairs"}], "]"}], 
        ",", 
        RowBox[{"Last", "->", "First"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"scored", "=", 
      RowBox[{"Score", "[", 
       RowBox[{"game", ",", 
        RowBox[{"Keys", "[", "grouped", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Association", "[", "\[IndentingNewLine]", 
      RowBox[{"Flatten", "[", "\[IndentingNewLine]", 
       RowBox[{"MapThread", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Thread", "[", 
           RowBox[{"#1", "->", 
            RowBox[{"ConstantArray", "[", 
             RowBox[{"#2", ",", 
              RowBox[{"Length", "[", "#1", "]"}]}], "]"}]}], "]"}], "&"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Values", "[", "grouped", "]"}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"aggregator", "===", "Total"}], "&&", 
              RowBox[{"ArrayQ", "[", "scored", "]"}], "&&", 
              RowBox[{
               RowBox[{"ArrayDepth", "[", "scored", "]"}], "==", "3"}]}], ",", 
             RowBox[{"Total", "[", 
              RowBox[{"scored", ",", 
               RowBox[{"{", "2", "}"}]}], "]"}], ",", 
             RowBox[{"aggregator", "/@", "scored"}]}], "]"}]}], "}"}]}], 
        "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", "]"}], 
      "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 

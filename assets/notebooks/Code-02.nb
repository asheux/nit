Cell[BoxData[{
 RowBox[{"Clear", "[", "TournamentScoreboardSimple", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "TournamentScoreboardSimple", "]"}], " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<WinningFunction\>\"", "->", " ", 
     RowBox[{"Function", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"p1payoff", ",", " ", "p2payoff"}], "}"}], ",", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"p1payoff", ">", "p2payoff"}], ",", " ", "1", ",", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"p1payoff", " ", "==", " ", "p2payoff"}], ",", " ", "0", ",",
            " ", 
           RowBox[{"-", "1"}]}], "]"}]}], "]"}]}], "]"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TournamentScoreboardSimple", "[", 
   RowBox[{"pairtotals_Association", ",", " ", 
    RowBox[{"ops", ":", 
     RowBox[{"OptionsPattern", "[", "TournamentScoreboardSimple", "]"}]}]}], 
   "]"}], ":=", " ", "\[IndentingNewLine]", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"totalpayoffs", " ", "=", 
      RowBox[{"Values", "[", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"<|", 
          RowBox[{"\"\<TotalPayoff\>\"", "->", "#"}], "|>"}], "&"}], "/@", 
        RowBox[{"Merge", "[", 
         RowBox[{
          RowBox[{"KeyValueMap", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"First", "[", "#1", "]"}], "->", 
              RowBox[{"First", "[", "#2", "]"}]}], "&"}], ",", "pairtotals"}],
            "]"}], ",", "Total"}], "]"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"Dataset", "[", 
     RowBox[{"ReverseSortBy", "[", 
      RowBox[{
       RowBox[{"MapThread", "[", 
        RowBox[{"Join", ",", 
         RowBox[{"{", " ", 
          RowBox[{
           RowBox[{"KeyValueMap", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"<|", 
               RowBox[{
                RowBox[{"\"\<ID\>\"", "->", " ", "#1"}], ",", " ", 
                RowBox[{"\"\<Wins\>\"", "->", 
                 RowBox[{"Count", "[", 
                  RowBox[{"#2", ",", " ", "1"}], "]"}]}], ",", " ", 
                RowBox[{"\"\<Ties\>\"", "->", 
                 RowBox[{"Count", "[", 
                  RowBox[{"#2", ",", " ", "0"}], "]"}]}], ",", " ", 
                RowBox[{"\"\<Losses\>\"", "->", 
                 RowBox[{"Count", "[", 
                  RowBox[{"#2", ",", " ", 
                   RowBox[{"-", "1"}]}], "]"}]}]}], "|>"}], "&"}], ",", 
             RowBox[{"Merge", "[", 
              RowBox[{
               RowBox[{"KeyValueMap", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{"First", "[", "#1", "]"}], "->", 
                   RowBox[{
                    RowBox[{
                    "OptionValue", "[", "\"\<WinningFunction\>\"", "]"}], "@@",
                     "#2"}]}], "&"}], ",", "pairtotals"}], "]"}], ",", " ", 
               "Identity"}], "]"}]}], "]"}], ",", "totalpayoffs"}], "}"}]}], 
        "]"}], " ", ",", " ", 
       RowBox[{"#Wins", "&"}]}], "]"}], "]"}]}], "]"}]}]}], "Input",

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "TitForTatQ", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TitForTatQ", "[", 
   RowBox[{"history_", ",", 
    RowBox[{"player_", ":", "1"}], ",", " ", 
    RowBox[{"firstmove_", ":", "0"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"me", ",", "opp"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"me", ",", "opp"}], "}"}], "=", 
      RowBox[{"Transpose", "[", "history", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"player", "===", "2"}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"me", ",", "opp"}], "}"}], "=", 
        RowBox[{"{", 
         RowBox[{"opp", ",", "me"}], "}"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"me", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "===", "firstmove"}], "&&", 
      RowBox[{
       RowBox[{"Rest", "[", "me", "]"}], "===", 
       RowBox[{"Most", "[", "opp", "]"}]}]}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellLabel->"In[33]:=",ExpressionUUID->"c8d8c2a0-2c36-41b9-8425-af9e068bb767"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "TitForTatFSMQ", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"TitForTatFSMQ", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"id_Integer", "?", "NonNegative"}], ",", 
      RowBox[{"s_Integer", "?", "Positive"}], ",", 
      RowBox[{"k_Integer", "?", "Positive"}]}], "}"}], ",", 
    RowBox[{"firstmove_", ":", "0"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "rules", ",", "assoc", ",", "inputs", ",", "reach", ",", "next"}], "}"}],
     ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"rules", "=", 
      RowBox[{"FiniteStateMachineToRule", "[", 
       RowBox[{"{", 
        RowBox[{"id", ",", "s", ",", "k"}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"assoc", "=", 
      RowBox[{"Association", "[", "rules", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"inputs", "=", 
      RowBox[{"Range", "[", 
       RowBox[{"0", ",", 
        RowBox[{"k", "-", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"reach", "=", 
      RowBox[{"{", "1", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{"True", ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"next", "=", 
         RowBox[{"Union", "[", 
          RowBox[{"reach", ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"assoc", "/@", 
              RowBox[{"Tuples", "[", 
               RowBox[{"{", 
                RowBox[{"reach", ",", "inputs"}], "}"}], "]"}]}], ")"}], "[", 
            
            RowBox[{"[", 
             RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"next", "===", "reach"}], ",", 
          RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"reach", "=", "next"}], ";"}]}], "\[IndentingNewLine]", "]"}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"!", 
        RowBox[{"AllTrue", "[", 
         RowBox[{
          RowBox[{"Tuples", "[", 
           RowBox[{"{", 
            RowBox[{"reach", ",", "inputs"}], "}"}], "]"}], ",", 
          RowBox[{
           RowBox[{"With", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"key", "=", "#"}], "}"}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"assoc", "[", "key", "]"}], "[", 
               RowBox[{"[", "2", "]"}], "]"}], "===", 
              RowBox[{"key", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "&"}]}], "]"}]}], ",", 
       RowBox[{"Return", "[", "False", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"firstmove", "===", 
      RowBox[{
       RowBox[{"IteratedGame", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"FSMStrategyFunction", "[", 
            RowBox[{"{", 
             RowBox[{"id", ",", "s", ",", "k"}], "}"}], "]"}], ",", 
           RowBox[{"FSMStrategyFunction", "[", 
            RowBox[{"{", 
             RowBox[{"id", ",", "s", ",", "k"}], "}"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", "}"}], ",", "1"}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.981072472028245*^9, 3.981072684465932*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"aa64a148-7c51-4607-b944-5387c0aeb245"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "CycleLengthsFromStep", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CycleLengthsFromStep", "[", 
   RowBox[{"step_", ",", "init_", ",", 
    RowBox[{"maxsteps_", ":", "Infinity"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"seen", "=", 
       RowBox[{"<|", "|>"}]}], ",", 
      RowBox[{"state", "=", "init"}], ",", 
      RowBox[{"t", "=", "0"}], ",", "first"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"t", "<", "maxsteps"}], "&&", 
        RowBox[{"!", 
         RowBox[{"KeyExistsQ", "[", 
          RowBox[{"seen", ",", "state"}], "]"}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"seen", "[", "state", "]"}], "=", "t"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"state", "=", 
         RowBox[{"step", "[", 
          RowBox[{"Sequence", "@@", "state"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"t", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"t", ">=", "maxsteps"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"Infinity", ",", "Infinity"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"first", "=", 
         RowBox[{"seen", "[", "state", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"first", ",", 
          RowBox[{"t", "-", "first"}]}], "}"}]}]}], "\[IndentingNewLine]", 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}], "Input",
 CellChangeTimes->{{3.980867268810978*^9, 3.980867421884035*^9}, {
  3.980867536614448*^9, 3.980867541376457*^9}, {3.980868221696636*^9, 

        RowBox[{"IntegerDigits", "[", 
         RowBox[{"t", ",", "s", ",", "n"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"out", "=", 
      RowBox[{"If", "[", 

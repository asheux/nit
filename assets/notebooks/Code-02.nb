             RowBox[{"{", "1", "}"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"rows", "=", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"<|", 
               RowBox[{
                RowBox[{"\"\<Program\>\"", "->", 
                 RowBox[{"labels", "[", 
                  RowBox[{"[", "1", "]"}], "]"}]}], ",", 
                RowBox[{"\"\<ID\>\"", "->", 
                 RowBox[{"ids", "[", 
                  RowBox[{"[", "i", "]"}], "]"}]}], ",", 

                RowBox[{
                 RowBox[{"-", "0.15"}], "*", "scale"}]}], "}"}]}], ",", 
             RowBox[{"pos", "[", "initv", "]"}]}], "}"}], "]"}]}], "}"}]}]}], 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}], "\n", 

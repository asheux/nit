Cell[BoxData[{
 RowBox[{"ClearAll", "[", "coord", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"coord", "[", 
   RowBox[{"seq_", ",", 
    RowBox[{"dim_", ":", "3"}], ",", 
    RowBox[{"scale_", ":", "0.7"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"len", "=", 
       RowBox[{"Length", "[", "seq", "]"}]}], ",", 
      RowBox[{"sg", "=", 
       RowBox[{
        RowBox[{"2", " ", "seq"}], "-", "1"}]}], ",", "st", ",", "contrib", ",",
       "idx"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"st", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"len", "==", "0"}], ",", 
        RowBox[{"{", "}"}], ",", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", "1", "}"}], ",", 
          RowBox[{"scale", "^", 
           RowBox[{"Range", "[", 
            RowBox[{"1", ",", 
             RowBox[{"len", "-", "1"}]}], "]"}]}]}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"contrib", "=", 
      RowBox[{"sg", "*", "st"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"idx", "=", 
      RowBox[{"Range", "[", "len", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"dim", "==", "3"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"Pick", "[", 
           RowBox[{"contrib", ",", 
            RowBox[{"OddQ", "/@", "idx"}]}], "]"}], "]"}], ",", 
         RowBox[{"Total", "[", 
          RowBox[{"Pick", "[", 
           RowBox[{"contrib", ",", 
            RowBox[{"EvenQ", "/@", "idx"}]}], "]"}], "]"}], ",", "len"}], 
        "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"Pick", "[", 
           RowBox[{"contrib", ",", 
            RowBox[{"OddQ", "/@", "idx"}]}], "]"}], "]"}], ",", 
         RowBox[{"Total", "[", 
          RowBox[{"Pick", "[", 
           RowBox[{"contrib", ",", 
            RowBox[{"EvenQ", "/@", "idx"}]}], "]"}], "]"}]}], "}"}]}], 
      "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.979744792082512*^9, 3.97974491751473*^9}, {
  3.979744957340315*^9, 3.979744995332488*^9}, {3.979747007546805*^9, 

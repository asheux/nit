 RowBox[{
  RowBox[{"TuringMachineStrategyPlot", "[", 
   RowBox[{
    RowBox[{"tm_", ":", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"_Integer", "?", "NonNegative"}], ",", 
       RowBox[{"_Integer", "?", "Positive"}], ",", 
       RowBox[{"_Integer", "?", "Positive"}]}], "}"}]}], ",", "history_List", 
    ",", "maxsteps_Integer", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"input", ",", "out", ",", "plot", ",", "shown", ",", 
      RowBox[{"ascallo", "=", 
       RowBox[{"OptionValue", "[", "\"\<AsCallout\>\"", "]"}]}]}], "}"}], ",",
     "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"out", " ", "=", " ", 
      RowBox[{
       RowBox[{"TuringMachineStrategy", "[", 
        RowBox[{"tm", ",", "maxsteps"}], "]"}], "[", 
       RowBox[{"history", ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"input", "=", 
      RowBox[{"HistoryToInput", "[", "history", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"plot", "=", 
      RowBox[{"OneSidedTuringMachinePlot", "[", 
       RowBox[{"tm", ",", "input", ",", "maxsteps", ",", 
        RowBox[{"\"\<LabelOutput\>\"", "->", "False"}], ",", 
        RowBox[{"\"\<LabelInput\>\"", "->", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"TrueQ", "[", "ascallo", "]"}]}], "&&", 
          RowBox[{"TrueQ", "[", 
           RowBox[{"OptionValue", "[", "\"\<LabelInput\>\"", "]"}], 
           "]"}]}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"shown", "=", 
      RowBox[{"If", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"TrueQ", "[", "ascallo", "]"}], ",", "plot", ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"TrueQ", "[", 
            RowBox[{"Last", "[", "out", "]"}], "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Labeled", "[", 
            RowBox[{"plot", ",", 
             RowBox[{"Style", "[", 
              RowBox[{
               RowBox[{"First", "[", "out", "]"}], ",", "12"}], "]"}], ",", 
             "Bottom"}], "]"}], ",", "\[IndentingNewLine]", "Undefined"}], 
          "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"TrueQ", "[", 
            RowBox[{"OptionValue", "[", "\"\<WithOutput\>\"", "]"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"First", "[", "out", "]"}], ",", "shown"}], "}"}], ",", 
           "shown"}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}]}], 
   "]"}]}]}], "Input",

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "FSMStateStepFunction", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FSMStateStepFunction", "::", "usage"}], 
   "=", "\"\<FSMStateStepFunction[{id1, id2}, s, k] returns a pure function \
ste[q1,q2] that advances the *joint FSM state* by one round \
(player-symmetric).\>\""}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FSMStateStepFunction", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"id1_Integer", "?", "NonNegative"}], ",", 
      RowBox[{"id2_Integer", "?", "NonNegative"}]}], "}"}], ",", 
    RowBox[{"s_Integer", "?", "Positive"}], ",", 
    RowBox[{"k_Integer", "?", "Positive"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r1", ",", "r2", ",", "out1", ",", "out2"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"r1", "=", 
      RowBox[{"FiniteStateMachineToRule", "[", 
       RowBox[{"{", 
        RowBox[{"id1", ",", "s", ",", "k"}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"r2", "=", 
      RowBox[{"FiniteStateMachineToRule", "[", 
       RowBox[{"{", 
        RowBox[{"id2", ",", "s", ",", "k"}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"out1", "=", 
      RowBox[{"Association", "[", 
       RowBox[{"DeleteDuplicates", "[", 
        RowBox[{"Rule", "@@@", 
         RowBox[{"(", 
          RowBox[{"Last", "/@", "r1"}], ")"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"out2", "=", 
      RowBox[{"Association", "[", 
       RowBox[{"DeleteDuplicates", "[", 
        RowBox[{"Rule", "@@@", 
         RowBox[{"(", 
          RowBox[{"Last", "/@", "r2"}], ")"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Function", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"q1", ",", "q2"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"First", "[", 
          RowBox[{
           RowBox[{"Association", "[", "r1", "]"}], "[", 
           RowBox[{"{", 
            RowBox[{"q1", ",", 
             RowBox[{"out2", "[", "q2", "]"}]}], "}"}], "]"}], "]"}], ",", 
         RowBox[{"First", "[", 
          RowBox[{
           RowBox[{"Association", "[", "r2", "]"}], "[", 
           RowBox[{"{", 
            RowBox[{"q2", ",", 
             RowBox[{"out1", "[", "q1", "]"}]}], "}"}], "]"}], "]"}]}], 
        "}"}]}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}], "Input",
 CellChangeTimes->{{3.980866686808732*^9, 3.9808669603995323`*^9}, {

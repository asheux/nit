 RowBox[{
  RowBox[{"FiniteStateMachineToRule", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"i_Integer", "?", "NonNegative"}], ",", 
     RowBox[{"s_Integer", "?", "Positive"}], ",", 
     RowBox[{"k_Integer", "?", "Positive"}]}], "}"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"n", "=", 
       RowBox[{"s", " ", "k"}]}], ",", 
      RowBox[{"max", "=", 
       RowBox[{"FSMCount", "[", 
        RowBox[{"s", ",", "k"}], "]"}]}], ",", "t", ",", "o", ",", "nxt", ",",
       "out"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"i", ">=", "max"}], ",", 
       RowBox[{
        RowBox[{"Message", "[", 
         RowBox[{

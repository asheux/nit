Cell[BoxData[{
 RowBox[{"ClearAll", "[", "HeadToHeadMatrixPlot", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "HeadToHeadMatrixPlot", "]"}], "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\"\<ShowPlotLabel\>\"", "->", "True"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<RotateXLabels\>\"", "->", "True"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<SortPlayers\>\"", "->", "True"}]}], "\[IndentingNewLine]", 
    "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"HeadToHeadMatrixPlot", "[", 
   RowBox[{"totals_", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "keys", ",", "players", ",", "pos", ",", "n", ",", "rules", ",", 
      "xlabs"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"keys", "=", 
      RowBox[{"Keys", "[", "totals", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"players", "=", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"keys", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
         RowBox[{"keys", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"TrueQ", "[", 
        RowBox[{"OptionValue", "[", "\"\<SortPlayers\>\"", "]"}], "]"}], ",", 
       
       RowBox[{"players", "=", 
        RowBox[{"Sort", "[", "players", "]"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pos", "=", 
      RowBox[{"AssociationThread", "[", 
       RowBox[{"players", "->", 
        RowBox[{"Range", "[", 
         RowBox[{"Length", "[", "players", "]"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"n", "=", 
      RowBox[{"Length", "[", "players", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rules", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{"KeyValueMap", "[", 
        RowBox[{
         RowBox[{"Function", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"p", ",", "v"}], "}"}], ",", 
           RowBox[{"With", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"i", "=", 
                RowBox[{"pos", "[", 
                 RowBox[{"p", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ",", 
               RowBox[{"j", "=", 
                RowBox[{"pos", "[", 
                 RowBox[{"p", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ",", 
               RowBox[{"d", "=", 
                RowBox[{"Subtract", "@@", "v"}]}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"i", ",", "j"}], "}"}], "->", "d"}], ",", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"j", ",", "i"}], "}"}], "->", 
                RowBox[{"-", "d"}]}]}], "}"}]}], "]"}]}], "]"}], ",", 

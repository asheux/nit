Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "ScanGameWinnersSlow", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "ScanGameWinnersSlow", "]"}], "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\"\<ProgramLabels\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Prog1\>\"", ",", "\"\<Prog2\>\""}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<MachineShape\>\"", "->", 

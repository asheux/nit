Cell[BoxData[{
 RowBox[{"ClearAll", "[", "MultiwayGames", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MultiwayGames", "[", 
   RowBox[{"gamematrix_", ",", "steps_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"g", ",", "lead"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"g", "[", "x_List", "]"}], ":=", 
      RowBox[{"Subtract", "@@", 
       RowBox[{"Total", "[", 
        RowBox[{"Score", "[", 
         RowBox[{"gamematrix", ",", 
          RowBox[{"Partition", "[", 
           RowBox[{"x", ",", "2"}], "]"}]}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"lead", "[", "x_List", "]"}], ":=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"g", "[", "x", "]"}], ">=", "0"}], ",", 
        RowBox[{"g", "[", "x", "]"}], ",", 
        RowBox[{"-", 
         RowBox[{"g", "[", "x", "]"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"LayeredGraph", "[", 
      RowBox[{
       RowBox[{"NestGraph", "[", 
        RowBox[{
         RowBox[{"Function", "[", 
          RowBox[{"u", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"Join", "[", 
              RowBox[{"u", ",", "#"}], "]"}], "&"}], "/@", 
            RowBox[{"Tuples", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"0", ",", "1"}], "}"}], ",", "2"}], "]"}]}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"{", "}"}], "}"}], ",", "steps", ",", "\[IndentingNewLine]", 
         RowBox[{"VertexStyle", "->", 
          RowBox[{"(", 
           RowBox[{"x_", ":>", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"x", "===", 
               RowBox[{"{", "}"}]}], ",", "Gray", ",", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"g", "[", "x", "]"}], ">", "0"}], ",", 
                "StandardBlue", ",", "StandardRed"}], "]"}]}], "]"}]}], 
           ")"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"VertexSize", "->", 
          RowBox[{"(", 
           RowBox[{"x_", ":>", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"x", "===", 
               RowBox[{"{", "}"}]}], ",", "0", ",", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"lead", "[", "x", "]"}], "+", "1"}], ")"}], "^", 
               ".2"}]}], "]"}]}], ")"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"VertexShapeFunction", "->", 
          RowBox[{"Function", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"pos", ",", "vertex", ",", "size"}], "}"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Module", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
               "size2", ",", "inset", ",", "insetsize", ",", "tiny", ",", 
                "disks"}], "}"}], ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"size2", "=", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"ListQ", "[", "size", "]"}], ",", "size", ",", 
                  RowBox[{"{", 
                   RowBox[{"size", ",", "size"}], "}"}]}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"tiny", "=", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"vertex", "=!=", 
                    RowBox[{"{", "}"}]}], "&&", 
                   RowBox[{
                    RowBox[{"lead", "[", "vertex", "]"}], "<=", 
                    RowBox[{"10", "^", 
                    RowBox[{"-", "9"}]}]}]}], ")"}], "||", 
                 RowBox[{
                  RowBox[{"Max", "[", "size2", "]"}], "<=", "0"}]}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"insetsize", "=", 
                RowBox[{"If", "[", 
                 RowBox[{"tiny", ",", 
                  RowBox[{"{", 
                   RowBox[{"0.9", ",", "0.9"}], "}"}], ",", 
                  RowBox[{"0.95", "*", 
                   RowBox[{"Sqrt", "[", "2", "]"}], "*", "size2"}]}], "]"}]}],
                ";", "\[IndentingNewLine]", 
               RowBox[{"inset", "=", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"vertex", "===", 
                   RowBox[{"{", "}"}]}], ",", 
                  RowBox[{"{", "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"Opacity", "[", "1", "]"}], ",", 
                    RowBox[{"Inset", "[", 
                    RowBox[{
                    RowBox[{"ArrayPlot", "[", 
                    RowBox[{
                    RowBox[{"Partition", "[", 
                    RowBox[{"vertex", ",", "2"}], "]"}], ",", 
                    RowBox[{"Mesh", "->", "True"}], ",", 
                    RowBox[{"Frame", "->", "False"}], ",", 
                    RowBox[{"Background", "->", "None"}], ",", 
                    RowBox[{"PlotRangePadding", "->", "0"}], ",", 
                    RowBox[{"ImagePadding", "->", "0"}]}], "]"}], ",", "pos", 
                    ",", "Center", ",", "insetsize"}], "]"}]}], "}"}]}], 
                 "]"}]}], ";", "\[IndentingNewLine]", 
               RowBox[{"disks", "=", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"vertex", "===", 
                    RowBox[{"{", "}"}]}], "||", "tiny"}], ",", 
                  RowBox[{"{", "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"Opacity", "[", ".3", "]"}], ",", 
                    RowBox[{"Disk", "[", 
                    RowBox[{"pos", ",", "size2"}], "]"}]}], "}"}]}], "]"}]}], 
               ";", "\[IndentingNewLine]", 
               RowBox[{"Join", "[", 
                RowBox[{"disks", ",", "inset"}], "]"}]}]}], 
             "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}]}],
         "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"AspectRatio", "->", 
        RowBox[{"1", "/", "5"}]}]}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",

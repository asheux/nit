    RowBox[{"initrules_", ":", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"_Integer", "?", "NonNegative"}], ",", 
         RowBox[{"_Integer", "?", "Positive"}], ",", 
         RowBox[{"_Integer", "?", "ValidCARangeQ"}]}], "}"}], ".."}], "}"}]}],
     ",", 

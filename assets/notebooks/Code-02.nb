Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", "Score", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Score", "[", 
     RowBox[{
      RowBox[{"gamematrix_", "/;", 
       RowBox[{"ArrayQ", "[", 
        RowBox[{"gamematrix", ",", "3"}], "]"}]}], ",", 
      RowBox[{
       RowBox[{"outcome", ":", 
        RowBox[{"{", 
         RowBox[{"a_", ",", "b_"}], "}"}]}], "/;", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"ListQ", "[", "a", "]"}]}], "&&", 
        RowBox[{"!", 
         RowBox[{"ListQ", "[", "b", "]"}]}]}]}]}], "]"}], ":=", 
    RowBox[{"Extract", "[", 
     RowBox[{"gamematrix", ",", 

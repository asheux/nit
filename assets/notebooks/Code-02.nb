Cell[BoxData[{
 RowBox[{"ClearAll", "[", "FSMStrategyFunction", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FSMStrategyFunction", "[", 
   RowBox[{"fsmrules_List", ",", 
    RowBox[{"init_", ":", "1"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"actions", ",", "move", ",", 
      RowBox[{"state", "=", "init"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"actions", "=", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Rule", "@@", 
          RowBox[{"Last", "[", "#", "]"}]}], "&"}], "/@", "fsmrules"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Function", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"history", ",", "player"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"last", "=", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"history", "===", 
              RowBox[{"{", "}"}]}], ",", 
             RowBox[{"Missing", "[", "\"\<Start\>\"", "]"}], ",", 
             RowBox[{"Last", "[", "history", "]"}]}], "]"}]}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"last", "===", 
            RowBox[{"Missing", "[", "\"\<Start\>\"", "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Replace", "[", 
            RowBox[{"state", ",", "actions"}], "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Module", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"oi", "=", 
               RowBox[{"last", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"Mod", "[", 
                   RowBox[{"player", ",", "2"}], "]"}], "+", "1"}], "]"}], 
                "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"move", "=", 
               RowBox[{"Lookup", "[", 
                RowBox[{
                 RowBox[{"Association", "[", "fsmrules", "]"}], ",", 
                 RowBox[{"Key", "[", 
                  RowBox[{"{", 
                   RowBox[{"state", ",", "oi"}], "}"}], "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"state", ",", 
                   RowBox[{"Replace", "[", 
                    RowBox[{"state", ",", "actions"}], "]"}]}], "}"}]}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"state", "=", 
               RowBox[{"First", "[", "move", "]"}]}], ";", 

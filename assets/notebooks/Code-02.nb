Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "TournamentWinLossPlots", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TournamentWinLossPlots", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"prog1_String", ",", "prog2_String"}], "}"}], ",", 
    "pairTotals_Association", ",", 
    RowBox[{"top_", ":", "25"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "rows", ",", "topn", ",", "color", ",", "lab", ",", "tip", ",", "best", ",",
       "worst", ",", "legend"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"rows", "=", 
      RowBox[{"Normal", "[", 
       RowBox[{"TournamentScoreboard", "[", 

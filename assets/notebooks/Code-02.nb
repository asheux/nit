 RowBox[{
  RowBox[{"ClearAll", "[", "OutcomeRowColSumsFromAssociation", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"OutcomeRowColSumsFromAssociation", "[", 

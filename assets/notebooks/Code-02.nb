Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "ContractionGraphPlot", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "ContractionGraphPlot", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<ShowFixedPoints\>\"", "->", "True"}], ",", 
     RowBox[{"VertexSize", "->", "Automatic"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ContractionGraphPlot", "[", 
   RowBox[{"data_Association", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"map", "=", 
       RowBox[{"data", "[", "\"\<RepresentativeByItem\>\"", "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"reps", "=", 
       RowBox[{"data", "[", "\"\<Representatives\>\"", "]"}]}], ",", "rules", 
      ",", "\[IndentingNewLine]", 
      RowBox[{"vsize", "=", 
       RowBox[{"OptionValue", "[", "VertexSize", "]"}]}]}], 
     "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"rules", "=", 
      RowBox[{"Normal", "[", "map", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"!", 
        RowBox[{"TrueQ", "[", 
         RowBox[{"OptionValue", "[", "\"\<ShowFixedPoints\>\"", "]"}], 
         "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"rules", "=", 
         RowBox[{"Select", "[", 
          RowBox[{"rules", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"First", "[", "#", "]"}], "=!=", 
             RowBox[{"Last", "[", "#", "]"}]}], "&"}]}], "]"}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Graph", "[", 
      RowBox[{
       RowBox[{"DirectedEdge", "@@@", "rules"}], ",", "\[IndentingNewLine]", 
       RowBox[{"VertexLabels", "->", 
        RowBox[{"Placed", "[", 
         RowBox[{"\"\<Name\>\"", ",", "Center"}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"VertexStyle", "->", 
        RowBox[{"v_", ":>", 
         RowBox[{"(", 
          RowBox[{"v", "/.", 
           RowBox[{"Thread", "[", 
            RowBox[{"reps", "->", 
             RowBox[{"Directive", "[", 
              RowBox[{"Red", ",", 
               RowBox[{"Opacity", "[", "1", "]"}]}], "]"}]}], "]"}]}], 
          ")"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"GraphLayout", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<LayeredDigraphEmbedding\>\"", ",", 
          RowBox[{"\"\<Orientation\>\"", "->", "Left"}]}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"VertexSize", "->", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"vsize", "===", "Automatic"}], ",", 
          RowBox[{"0.1", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"Length", "[", "rules", "]"}], "]"}]}], ",", "vsize"}], 
         "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"ImageSize", "->", "Large"}]}], "\[IndentingNewLine]", 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}], "Input",
 CellChangeTimes->{{3.9811175577511044`*^9, 3.981117627138167*^9}, {

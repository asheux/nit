Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "TournamentScoreboard", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "TournamentScoreboard", "]"}], "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\"\<WinningFunction\>\"", "->", "Subtract"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<SortKey\>\"", "->", "Automatic"}]}], 
    RowBox[{"(*", 
     RowBox[{"Automatic", " ", "|", " ", "TotalPayoff"}], "*)"}], 
    "\[IndentingNewLine]", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TournamentScoreboard", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"prog1_", ",", "prog2_"}], "}"}], ",", "pairtotals_Association", 
    ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"winningfn", "=", 
       RowBox[{"OptionValue", "[", "\"\<WinningFunction\>\"", "]"}]}], ",", 
      "stats", ",", "rows", ",", "sorter"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"stats", "=", 
      RowBox[{"Merge", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"KeyValueMap", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"key", ",", "payoff"}], "}"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"With", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"p1", "=", 
                  RowBox[{
                   RowBox[{"player", "[", "prog1", "]"}], "[", 
                   RowBox[{"key", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ",", 
                 RowBox[{"p2", "=", 
                  RowBox[{
                   RowBox[{"player", "[", "prog2", "]"}], "[", 
                   RowBox[{"key", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ",", 
                 RowBox[{"m", "=", 
                  RowBox[{"Sign", "[", 
                   RowBox[{"winningfn", "@@", "payoff"}], "]"}]}]}], "}"}], ",",
                "\[IndentingNewLine]", 
               RowBox[{"{", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"p1", "->", 
                  RowBox[{"{", 
                   RowBox[{"1", ",", 
                    RowBox[{"Boole", "[", 
                    RowBox[{"m", "==", "1"}], "]"}], ",", 
                    RowBox[{"Boole", "[", 
                    RowBox[{"m", "==", 
                    RowBox[{"-", "1"}]}], "]"}], ",", 
                    RowBox[{"Boole", "[", 
                    RowBox[{"m", "==", "0"}], "]"}], ",", "m", ",", 
                    RowBox[{"payoff", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], "}"}]}], ",", 
                 RowBox[{"p2", "->", 
                  RowBox[{"{", 
                   RowBox[{"1", ",", 
                    RowBox[{"Boole", "[", 
                    RowBox[{"m", "==", 
                    RowBox[{"-", "1"}]}], "]"}], ",", 
                    RowBox[{"Boole", "[", 
                    RowBox[{"m", "==", "1"}], "]"}], ",", 
                    RowBox[{"Boole", "[", 
                    RowBox[{"m", "==", "0"}], "]"}], ",", 
                    RowBox[{"-", "m"}], ",", 
                    RowBox[{"payoff", "[", 
                    RowBox[{"[", "2", "]"}], "]"}]}], "}"}]}]}], 
                "\[IndentingNewLine]", "}"}]}], "]"}]}], 
            "\[IndentingNewLine]", "]"}], ",", "pairtotals"}], 
          "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", "]"}], ",", 
        "Total"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rows", "=", 
      RowBox[{"KeyValueMap", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"pl", ",", "v"}], "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{"With", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"g", "=", 
               RowBox[{"v", "[", 
                RowBox[{"[", "1", "]"}], "]"}]}], ",", 
              RowBox[{"w", "=", 
               RowBox[{"v", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], ",", 
              RowBox[{"l", "=", 
               RowBox[{"v", "[", 
                RowBox[{"[", "3", "]"}], "]"}]}], ",", 
              RowBox[{"t", "=", 
               RowBox[{"v", "[", 
                RowBox[{"[", "4", "]"}], "]"}]}], ",", 
              RowBox[{"ms", "=", 
               RowBox[{"v", "[", 
                RowBox[{"[", "5", "]"}], "]"}]}], ",", 
              RowBox[{"ps", "=", 
               RowBox[{"v", "[", 
                RowBox[{"[", "6", "]"}], "]"}]}]}], "}"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"<|", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"\"\<Program\>\"", "->", 
               RowBox[{"pl", "[", 
                RowBox[{"[", "1", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
              
              RowBox[{"\"\<ID\>\"", "->", 
               RowBox[{"pl", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
              
              RowBox[{"\"\<Label\>\"", "->", 
               RowBox[{"plabel", "[", "pl", "]"}]}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"\"\<Wins\>\"", "->", "w"}], ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<Losses\>\"", "->", "l"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"\"\<Ties\>\"", "->", "t"}], ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<Games\>\"", "->", "g"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"\"\<WinRate\>\"", "->", 
               RowBox[{"N", "[", 
                RowBox[{"w", "/", 
                 RowBox[{"Max", "[", 
                  RowBox[{"1", ",", "g"}], "]"}]}], "]"}]}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"\"\<LossRate\>\"", "->", 
               RowBox[{"N", "[", 
                RowBox[{"l", "/", 
                 RowBox[{"Max", "[", 
                  RowBox[{"1", ",", "g"}], "]"}]}], "]"}]}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"\"\<NetWins\>\"", "->", 
               RowBox[{"w", "-", "l"}]}], ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<MarginSum\>\"", "->", "ms"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"\"\<AvgMargin\>\"", "->", 
               RowBox[{"N", "[", 
                RowBox[{"ms", "/", 
                 RowBox[{"Max", "[", 
                  RowBox[{"1", ",", "g"}], "]"}]}], "]"}]}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"\"\<TotalPayoff\>\"", "->", "ps"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"\"\<AvgPayoff\>\"", "->", 
               RowBox[{"N", "[", 
                RowBox[{"ps", "/", 
                 RowBox[{"Max", "[", 
                  RowBox[{"1", ",", "g"}], "]"}]}], "]"}]}]}], 
             "\[IndentingNewLine]", "|>"}]}], "\[IndentingNewLine]", "]"}]}], 
         "\[IndentingNewLine]", "]"}], ",", "stats"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"sorter", "=", 
      RowBox[{"Switch", "[", 
       RowBox[{
        RowBox[{"OptionValue", "[", "\"\<SortKey\>\"", "]"}], ",", 
        "\[IndentingNewLine]", "\"\<TotalPayoff\>\"", ",", 
        RowBox[{
         RowBox[{"-", "#TotalPayoff"}], "&"}], ",", "\[IndentingNewLine]", 
        "_", ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "#WinRate"}], ",", 
           RowBox[{"-", "#Wins"}], ",", 
           RowBox[{"-", "#NetWins"}], ",", 
           RowBox[{"-", "#MarginSum"}], ",", 
           RowBox[{"-", "#TotalPayoff"}]}], "}"}], "&"}]}], 
       "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Dataset", "[", 
      RowBox[{"SortBy", "[", 
       RowBox[{"rows", ",", "sorter"}], "]"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TournamentScoreboard", "[", 
   RowBox[{"pairtotals_Association", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"TournamentScoreboard", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<Prog1\>\"", ",", "\"\<Prog2\>\""}], "}"}], ",", 
    "pairtotals", ",", "opts"}], "]"}]}]}], "Input",

    RowBox[{
     RowBox[{"pos", "=", 
      RowBox[{"AssociationThread", "[", 
       RowBox[{"ids", "->", 
        RowBox[{"Range", "[", "n", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"row", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0.", ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "4"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"col", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0.", ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "4"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"KeyValueMap", "[", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"p", ",", "c"}], "}"}], ",", 
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"i", "=", 
              RowBox[{"Lookup", "[", 
               RowBox[{"pos", ",", 
                RowBox[{"p", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], ",", 
                RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], "]"}]}], ",", 
             RowBox[{"j", "=", 
              RowBox[{"Lookup", "[", 
               RowBox[{"pos", ",", 
                RowBox[{"p", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], ",", 
                RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], "]"}]}], ",", 
             RowBox[{"v", "=", 
              RowBox[{"N", "[", "c", "]"}]}]}], "}"}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"IntegerQ", "[", "i", "]"}], "&&", 
              RowBox[{"IntegerQ", "[", "j", "]"}]}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"row", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "+=", "v"}], ";", 
              RowBox[{
               RowBox[{"col", "[", 
                RowBox[{"[", "j", "]"}], "]"}], "+=", "v"}]}]}], "]"}]}], 
          "]"}]}], "]"}], ",", "outcomecounts"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<IDs\>\"", "->", "ids"}], ",", 
       RowBox[{"\"\<RowCounts\>\"", "->", 
        RowBox[{"Developer`ToPackedArray", "[", "row", "]"}]}], ",", 
       RowBox[{"\"\<ColCounts\>\"", "->", 
        RowBox[{"Developer`ToPackedArray", "[", "col", "]"}]}]}], "|>"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.981146114126767*^9, 
  3.981146116290811*^9}},ExpressionUUID->"3b0af2a6-b1b8-4021-8a4a-\
5263857ef9e3"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "OutcomeRowColSumsSampled", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "OutcomeRowColSumsSampled", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<OpponentsPerMachine\>\"", "->", "256"}], ",", 
     RowBox[{"\"\<Parallel\>\"", "->", "True"}], ",", 
     RowBox[{"\"\<ChunkSize\>\"", "->", "64"}], ",", 
     RowBox[{"\"\<Seed\>\"", "->", "1234"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"OutcomeRowColSumsSampled", "[", 
   RowBox[{"builders_", ",", "ids_List", ",", 
    RowBox[{"rounds_Integer", "?", "Positive"}], ",", 
    RowBox[{"k_Integer", "?", "Positive"}], ",", 
    RowBox[{"inithistory_", ":", 
     RowBox[{"{", "}"}]}], ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"n", "=", 
       RowBox[{"Length", "[", "ids", "]"}]}], ",", 
      RowBox[{"o", "=", 
       RowBox[{"k", "^", "2"}]}], ",", 
      RowBox[{"m", "=", 
       RowBox[{"OptionValue", "[", "\"\<OpponentsPerMachine\>\"", "]"}]}], ",", 
      RowBox[{"par", "=", 
       RowBox[{"TrueQ", "[", 
        RowBox[{"OptionValue", "[", "\"\<Parallel\>\"", "]"}], "]"}]}], ",", 
      RowBox[{"chunk", "=", 
       RowBox[{"OptionValue", "[", "\"\<ChunkSize\>\"", "]"}]}], ",", 
      RowBox[{"seed", "=", 
       RowBox[{"OptionValue", "[", "\"\<Seed\>\"", "]"}]}], ",", "chunks", ",",
       "chunkFn", ",", "parts", ",", "row", ",", "col"}], "}"}], ",", 
    RowBox[{
     RowBox[{"chunks", "=", 
      RowBox[{"Partition", "[", 
       RowBox[{
        RowBox[{"Range", "[", "n", "]"}], ",", 
        RowBox[{"UpTo", "[", "chunk", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"chunkFn", "[", "idxs_", "]"}], ":=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"rowChunk", "=", 
           RowBox[{"ConstantArray", "[", 
            RowBox[{"0.", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Length", "[", "idxs", "]"}], ",", "o"}], "}"}]}], 
            "]"}]}], ",", 
          RowBox[{"colChunk", "=", 
           RowBox[{"ConstantArray", "[", 
            RowBox[{"0.", ",", 
             RowBox[{"{", 
              RowBox[{"n", ",", "o"}], "}"}]}], "]"}]}], ",", 
          RowBox[{"ii", "=", "0"}], ",", "opp", ",", "wt", ",", "c"}], "}"}], 
        ",", 
        RowBox[{
         RowBox[{"Do", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"ii", "++"}], ";", "\[IndentingNewLine]", 
            RowBox[{"SeedRandom", "[", 
             RowBox[{"seed", "+", "i"}], "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"opp", "=", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"m", ">=", "n"}], ",", 
               RowBox[{"Range", "[", "n", "]"}], ",", 
               RowBox[{"RandomSample", "[", 
                RowBox[{
                 RowBox[{"Range", "[", "n", "]"}], ",", "m"}], "]"}]}], 
              "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"wt", "=", 
             RowBox[{"N", "[", 
              RowBox[{"n", "/", 
               RowBox[{"Length", "[", "opp", "]"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Do", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"c", "=", 
                RowBox[{"wt", "*", 
                 RowBox[{"N", "@", 
                  RowBox[{"OutcomeCountVector", "[", 
                   RowBox[{
                    RowBox[{"IteratedGame", "[", 
                    RowBox[{
                    RowBox[{"MapThread", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"#1", "[", "#2", "]"}], "&"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"builders", ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"ids", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], ",", 
                    RowBox[{"ids", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "}"}]}], "}"}]}], "]"}],
                     ",", "inithistory", ",", "rounds"}], "]"}], ",", "k"}], 
                   "]"}]}]}]}], ";", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"rowChunk", "[", 
                 RowBox[{"[", "ii", "]"}], "]"}], "+=", "c"}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"colChunk", "[", 
                 RowBox[{"[", "j", "]"}], "]"}], "+=", "c"}], ";"}], ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", "opp"}], "}"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "idxs"}], "}"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<Rows\>\"", "->", "idxs"}], ",", 
           RowBox[{"\"\<RowChunk\>\"", "->", "rowChunk"}], ",", 
           RowBox[{"\"\<ColChunk\>\"", "->", "colChunk"}]}], "|>"}]}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"parts", "=", 
      RowBox[{"If", "[", 
       RowBox[{"par", ",", 
        RowBox[{"ParallelMap", "[", 
         RowBox[{"chunkFn", ",", "chunks", ",", 
          RowBox[{"Method", "->", "\"\<CoarsestGrained\>\""}]}], "]"}], ",", 
        RowBox[{"Map", "[", 
         RowBox[{"chunkFn", ",", "chunks"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"row", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0.", ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "o"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"col", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0.", ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "o"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"row", "[", 
          RowBox[{"[", 
           RowBox[{"p", "[", "\"\<Rows\>\"", "]"}], "]"}], "]"}], "+=", 
         RowBox[{"p", "[", "\"\<RowChunk\>\"", "]"}]}], ";", 
        RowBox[{"col", "+=", 
         RowBox[{"p", "[", "\"\<ColChunk\>\"", "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"p", ",", "parts"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<IDs\>\"", "->", "ids"}], ",", 
       RowBox[{"\"\<RowCounts\>\"", "->", 
        RowBox[{"Developer`ToPackedArray", "[", "row", "]"}]}], ",", 
       RowBox[{"\"\<ColCounts\>\"", "->", 
        RowBox[{"Developer`ToPackedArray", "[", "col", "]"}]}]}], "|>"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.981146107944345*^9, 3.981146139876932*^9}},
 CellLabel->"",ExpressionUUID->"38318f1f-641f-4be2-a58e-92538350ec2e"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "ScanGameWinnersFastTotalPayoff", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "ScanGameWinnersFastTotalPayoff", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<ProgramLabels\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Prog1\>\"", ",", "\"\<Prog2\>\""}], "}"}]}], ",", 
     RowBox[{"\"\<MachineShape\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"2", ",", "2"}], "}"}]}], ",", 
     RowBox[{"\"\<Parallel\>\"", "->", "True"}], ",", 
     RowBox[{"\"\<GameBatchSize\>\"", "->", "128"}], ",", 
     RowBox[{"\"\<ReturnDataset\>\"", "->", "True"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ScanGameWinnersFastTotalPayoff", "[", 
    RowBox[{"games_List", ",", "rc_Association", ",", 
     RowBox[{"opts", ":", 
      RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"labels", "=", 
        RowBox[{"OptionValue", "[", "\"\<ProgramLabels\>\"", "]"}]}], ",", 
       RowBox[{"shape", "=", 
        RowBox[{"OptionValue", "[", "\"\<MachineShape\>\"", "]"}]}], ",", 
       RowBox[{"par", "=", 
        RowBox[{"TrueQ", "[", 
         RowBox[{"OptionValue", "[", "\"\<Parallel\>\"", "]"}], "]"}]}], ",", 
       
       RowBox[{"bsz", "=", 
        RowBox[{"OptionValue", "[", "\"\<GameBatchSize\>\"", "]"}]}], ",", 
       RowBox[{"ids", "=", 
        RowBox[{"rc", "[", "\"\<IDs\>\"", "]"}]}], ",", 
       RowBox[{"row", "=", 
        RowBox[{"rc", "[", "\"\<RowCounts\>\"", "]"}]}], ",", 
       RowBox[{"col", "=", 
        RowBox[{"rc", "[", "\"\<ColCounts\>\"", "]"}]}], ",", "n", ",", "g", ",",
        "payFlat", ",", "p1", ",", "p2", ",", "batches", ",", "batchFn", ",", 
       "out"}], "}"}], ",", 
     RowBox[{
      RowBox[{"n", "=", 
       RowBox[{"Length", "[", "ids", "]"}]}], ";", 
      RowBox[{"g", "=", 
       RowBox[{"Length", "[", "games", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"payFlat", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{"#", ",", "1"}], "]"}], "&"}], "/@", "games"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"p1", "=", 
       RowBox[{"Developer`ToPackedArray", "@", 
        RowBox[{"N", "@", 
         RowBox[{"Transpose", "[", 
          RowBox[{"payFlat", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "All", ",", "1"}], "]"}], "]"}], "]"}]}]}]}], 
      ";", 
      RowBox[{"(*", 
       RowBox[{"4", " ", "x", " ", "g"}], "*)"}], 
      RowBox[{"p2", "=", 
       RowBox[{"Developer`ToPackedArray", "@", 
        RowBox[{"N", "@", 
         RowBox[{"Transpose", "[", 
          RowBox[{"payFlat", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "All", ",", "2"}], "]"}], "]"}], "]"}]}]}]}], 
      ";", 
      RowBox[{"(*", 
       RowBox[{"4", " ", "x", " ", "g"}], "*)"}], 
      RowBox[{"batches", "=", 
       RowBox[{"Partition", "[", 
        RowBox[{
         RowBox[{"Range", "[", "g", "]"}], ",", 
         RowBox[{"UpTo", "[", "bsz", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"batchFn", "[", "b_", "]"}], ":=", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "a", ",", "bb", ",", "prog1", ",", "prog2", ",", "s", ",", "pos", ",",
            "id", ",", "prg", ",", "score"}], "}"}], ",", 
         RowBox[{
          RowBox[{"a", "=", 
           RowBox[{"p1", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "b"}], "]"}], "]"}]}], ";", 
          RowBox[{"bb", "=", 
           RowBox[{"p2", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "b"}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"prog1", "=", 
           RowBox[{"0.5", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"row", ".", "a"}], "+", 
              RowBox[{"col", ".", "bb"}]}], ")"}]}]}], ";", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"n", " ", "x"}], "|", "b", "|"}], "*)"}], 
          RowBox[{"prog2", "=", 
           RowBox[{"0.5", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"col", ".", "a"}], "+", 
              RowBox[{"row", ".", "bb"}]}], ")"}]}]}], ";", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"n", " ", "x"}], "|", "b", "|"}], "*)"}], 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"s", "=", 
              RowBox[{"Join", "[", 
               RowBox[{
                RowBox[{"prog1", "[", 
                 RowBox[{"[", 
                  RowBox[{"All", ",", "t"}], "]"}], "]"}], ",", 
                RowBox[{"prog2", "[", 
                 RowBox[{"[", 
                  RowBox[{"All", ",", "t"}], "]"}], "]"}]}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"pos", "=", 
              RowBox[{"First", "@", 
               RowBox[{"Ordering", "[", 
                RowBox[{"s", ",", 
                 RowBox[{"-", "1"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
             
             RowBox[{"id", "=", 
              RowBox[{"ids", "[", 
               RowBox[{"[", 
                RowBox[{"1", "+", 
                 RowBox[{"Mod", "[", 
                  RowBox[{
                   RowBox[{"pos", "-", "1"}], ",", "n"}], "]"}]}], "]"}], 
               "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"prg", "=", 
              RowBox[{"labels", "[", 
               RowBox[{"[", 
                RowBox[{"1", "+", 
                 RowBox[{"Quotient", "[", 
                  RowBox[{
                   RowBox[{"pos", "-", "1"}], ",", "n"}], "]"}]}], "]"}], 
               "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"score", "=", 
              RowBox[{"s", "[", 
               RowBox[{"[", "pos", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<GameIndex\>\"", "->", 
                RowBox[{"b", "[", 
                 RowBox[{"[", "t", "]"}], "]"}]}], ",", 
               RowBox[{"\"\<Winner\>\"", "->", "id"}], ",", 
               RowBox[{"\"\<WinnerProgram\>\"", "->", "prg"}], ",", 
               RowBox[{"\"\<WinnerAvgPayoff\>\"", "->", 
                RowBox[{"N", "[", 
                 RowBox[{"score", "/", "n"}], "]"}]}], ",", 
               RowBox[{"\"\<WinnerComplexity\>\"", "->", 
                RowBox[{"MachineComplexity", "[", 
                 RowBox[{"{", 
                  RowBox[{"id", ",", 
                   RowBox[{"shape", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], ",", 
                   RowBox[{"shape", "[", 
                    RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "]"}]}], ",", 
               RowBox[{"\"\<Game\>\"", "->", 
                RowBox[{"ToString", "[", 
                 RowBox[{
                  RowBox[{"games", "[", 
                   RowBox[{"[", 
                    RowBox[{"b", "[", 
                    RowBox[{"[", "t", "]"}], "]"}], "]"}], "]"}], ",", 
                  "InputForm"}], "]"}]}]}], "|>"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"t", ",", 
              RowBox[{"Length", "[", "b", "]"}]}], "}"}]}], "]"}]}]}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"out", "=", 
       RowBox[{"If", "[", 
        RowBox[{"par", ",", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Length", "[", 
              RowBox[{"Kernels", "[", "]"}], "]"}], "==", "0"}], ",", 
            RowBox[{"LaunchKernels", "[", "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"DistributeDefinitions", "[", 
           RowBox[{
           "ids", ",", "row", ",", "col", ",", "p1", ",", "p2", ",", "n", ",",
             "labels", ",", "shape", ",", "games", ",", "batchFn"}], "]"}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"Join", "@@", 
           RowBox[{"ParallelMap", "[", 
            RowBox[{"batchFn", ",", "batches", ",", 
             RowBox[{"Method", "->", "\"\<CoarsestGrained\>\""}]}], "]"}]}]}],
          ",", 
         RowBox[{"Join", "@@", 
          RowBox[{"Map", "[", 
           RowBox[{"batchFn", ",", "batches"}], "]"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"TrueQ", "[", 
         RowBox[{"OptionValue", "[", "\"\<ReturnDataset\>\"", "]"}], "]"}], ",", 
        RowBox[{"Dataset", "[", "out", "]"}], ",", "out"}], "]"}]}]}], 
    "]"}]}], ";"}], "\n"}], "Input",
 CellChangeTimes->{{3.9811461534191723`*^9, 3.9811461579138412`*^9}},
 CellLabel->
  "In[269]:=",ExpressionUUID->"6513e69b-fa2b-4bae-8dc0-48175bc9b5b6"]
}, Closed]]

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "ScanGameWinners", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "ScanGameWinners", "]"}], "=", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\"\<ProgramLabels\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<Prog1\>\"", ",", "\"\<Prog2\>\""}], "}"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"\"\<MachineShape\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"2", ",", "2"}], "}"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"\"\<Parallel\>\"", "->", "True"}], ",", "\[IndentingNewLine]", 
      
      RowBox[{"\"\<ReturnDataset\>\"", "->", "True"}]}], 
     "\[IndentingNewLine]", "}"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", "LLMed", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ScanGameWinners", "[", 
   RowBox[{
   "games_List", ",", "pairs_List", ",", "outcomecounts_Association", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"labels", "=", 
       RowBox[{"OptionValue", "[", "\"\<ProgramLabels\>\"", "]"}]}], ",", 
      RowBox[{"shape", "=", 
       RowBox[{"OptionValue", "[", "\"\<MachineShape\>\"", "]"}]}], ",", 
      RowBox[{"par", "=", 
       RowBox[{"TrueQ", "[", 
        RowBox[{"OptionValue", "[", "\"\<Parallel\>\"", "]"}], "]"}]}], ",", 
      "ids", ",", "n", ",", "counts4", ",", "pay", ",", "sorter", ",", 
      "evalone", ",", "idx", ",", "chunks", ",", "out", ",", "k"}], "}"}], ",", 
    RowBox[{
     RowBox[{"ids", "=", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{"pairs", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"n", "=", 
      RowBox[{"Length", "[", "ids", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"pairs", "=!=", 
        RowBox[{"Tuples", "[", 
         RowBox[{"ids", ",", "2"}], "]"}]}], ",", 
       RowBox[{"Return", "[", "$Failed", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"counts4", "=", 
      RowBox[{"Developer`ToPackedArray", "@", 
       RowBox[{"N", "@", 

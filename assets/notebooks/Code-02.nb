       ")"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MoveTreeGraph2DScored", "[", 
   RowBox[{
    RowBox[{"w_Integer", "?", "NonNegative"}], ",", " ", 
    RowBox[{"ops", ":", 
     RowBox[{"OptionsPattern", "[", 
      RowBox[{"{", 
       RowBox[{"MoveTreeGraph2DScored", ",", " ", "Graph"}], "}"}], "]"}]}]}],
    "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "verts", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"verts", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Tuples", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "1"}], "}"}], ",", "d"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"d", ",", "0", ",", "w"}], "}"}]}], "]"}], ",", "1"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Graph", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"With", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"p", "=", "seq"}], ",", 
               RowBox[{"len", "=", 
                RowBox[{"d", "+", "1"}]}]}], "}"}], ",", 
             RowBox[{"DirectedEdge", "[", 
              RowBox[{"p", ",", 
               RowBox[{"Append", "[", 
                RowBox[{"p", ",", "b"}], "]"}]}], "]"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"d", ",", "0", ",", 
             RowBox[{"w", "-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"seq", ",", 
             RowBox[{"Tuples", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", "1"}], "}"}], ",", "d"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"b", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", "2"}], 
        "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Sequence", "@@", 
        RowBox[{"FilterRules", "[", 
         RowBox[{
          RowBox[{"{", "ops", "}"}], ",", " ", 
          RowBox[{"Options", "[", "Graph", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"VertexCoordinates", "->", 
        RowBox[{"Thread", "[", 
         RowBox[{"verts", "->", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"coord", "[", 
              RowBox[{"#", ",", "2"}], "]"}], "&"}], "/@", "verts"}], ")"}]}],
          "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"VertexSize", "->", ".25"}], ",", "\[IndentingNewLine]", 
       RowBox[{"ImageSize", "->", "700"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
       RowBox[{"EdgeStyle", "->", " ", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"e_", "/;", 
            RowBox[{"EvenQ", "[", 
             RowBox[{"Length", "[", 
              RowBox[{"e", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}], ":>", " ", 
           RowBox[{"Directive", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"OptionValue", "[", "\"\<PlayerColors\>\"", "]"}], "[", 
              
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             RowBox[{"OptionValue", "[", "\"\<EdgeStyle\>\"", "]"}]}], 
            "]"}]}], ",", " ", 
          RowBox[{
           RowBox[{"e_", "/;", 
            RowBox[{"OddQ", "[", 
             RowBox[{"Length", "[", 
              RowBox[{"e", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}], ":>", 
           RowBox[{"Directive", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"OptionValue", "[", "\"\<PlayerColors\>\"", "]"}], "[", 
              
              RowBox[{"[", "2", "]"}], "]"}], ",", " ", 
             RowBox[{"OptionValue", "[", "\"\<EdgeStyle\>\"", "]"}]}], 
            "]"}]}]}], "\[IndentingNewLine]", "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"VertexStyle", "->", 
        RowBox[{"v_", ":>", " ", 

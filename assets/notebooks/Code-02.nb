Cell[BoxData[{
 RowBox[{"ClearAll", "[", "CanonicalCore", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CanonicalCore", "[", 
   RowBox[{
    RowBox[{"s_Integer", "?", "Positive"}], ",", 
    RowBox[{"k_Integer", "?", "Positive"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"CanonicalCore", "[", 
    RowBox[{"s", ",", "k"}], "]"}], "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"s0", "=", "s"}], ",", 
       RowBox[{"k0", "=", "k"}], ",", 
       RowBox[{"n0", "=", 
        RowBox[{"s", " ", "k"}]}], ",", 
       RowBox[{"out0", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"k", "==", "1"}], ",", "1", ",", 
          RowBox[{"k", "^", "s"}]}], "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"idx", ",", "_Integer"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"st0", ",", "_Integer"}], "}"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"tmp", "=", 
            RowBox[{"idx", "-", "1"}]}], ",", "tidx", ",", "oidx", ",", 
           RowBox[{"tab", "=", 
            RowBox[{"Table", "[", 
             RowBox[{"0", ",", 
              RowBox[{"{", "n0", "}"}]}], "]"}]}], ",", 
           RowBox[{"out", "=", 
            RowBox[{"Table", "[", 
             RowBox[{"0", ",", 
              RowBox[{"{", "s0", "}"}]}], "]"}]}], ",", 
           RowBox[{"map", "=", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"-", "1"}], ",", 
              RowBox[{"{", "s0", "}"}]}], "]"}]}], ",", 
           RowBox[{"q", "=", 
            RowBox[{"Table", "[", 
             RowBox[{"0", ",", 
              RowBox[{"{", "s0", "}"}]}], "]"}]}], ",", 
           RowBox[{"key", "=", 
            RowBox[{"Table", "[", 
             RowBox[{"0", ",", 
              RowBox[{"{", 
               RowBox[{"s0", 
                RowBox[{"(", 
                 RowBox[{"k0", "+", "1"}], ")"}]}], "}"}]}], "]"}]}], ",", 
           RowBox[{"h", "=", "1"}], ",", 
           RowBox[{"t", "=", "1"}], ",", 
           RowBox[{"next", "=", "1"}], ",", 
           RowBox[{"st", "=", "st0"}], ",", "u", ",", "v", ",", "m", ",", "j",
            ",", 
           RowBox[{"p", "=", "1"}], ",", "len"}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Split", " ", "index", " ", "into", " ", "transition"}], "-", 
           RowBox[{"table", " ", "part", " ", "and", " ", "state"}], "-", 
           RowBox[{"action", " ", "part"}]}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"oidx", "=", 
           RowBox[{"Mod", "[", 
            RowBox[{"tmp", ",", "out0"}], "]"}]}], ";", 
          RowBox[{"tidx", "=", 
           RowBox[{"Quotient", "[", 
            RowBox[{"tmp", ",", "out0"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{
             RowBox[{"Decode", " ", "transitions", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"base", " ", "s0"}], ",", " ", 
                RowBox[{"length", " ", "s0", "*", "k0"}]}], ")"}]}], ":", " ", 
             RowBox[{"tab", "[", 
              RowBox[{"[", 
               RowBox[{
                RowBox[{"u", "*", "k0"}], "+", "m", "+", "1"}], "]"}], 
              "]"}]}], "=", " ", 
            RowBox[{"next", " ", "state"}]}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"s0", "!=", "1"}], ",", 
            RowBox[{"Do", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"tab", "[", 
                 RowBox[{"[", "j", "]"}], "]"}], "=", 
                RowBox[{"Mod", "[", 
                 RowBox[{"tidx", ",", "s0"}], "]"}]}], ";", 
               RowBox[{"tidx", "=", 
                RowBox[{"Quotient", "[", 
                 RowBox[{"tidx", ",", "s0"}], "]"}]}]}], ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", "n0", ",", "1", ",", 
                RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Decode", " ", "per"}], "-", 
              RowBox[{"state", " ", "actions", " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"base", " ", "k0"}], ",", " ", 
                 RowBox[{"length", " ", "s0"}]}], ")"}]}]}], ":", " ", 
             RowBox[{"out", "[", 
              RowBox[{"[", 
               RowBox[{"u", "+", "1"}], "]"}], "]"}]}], " ", "=", " ", 
            RowBox[{"action", " ", "in", " ", "state", " ", "u"}]}], "*)"}], 
          "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"k0", "!=", "1"}], ",", 
            RowBox[{"Do", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"out", "[", 
                 RowBox[{"[", "j", "]"}], "]"}], "=", 
                RowBox[{"Mod", "[", 
                 RowBox[{"oidx", ",", "k0"}], "]"}]}], ";", 
               RowBox[{"oidx", "=", 
                RowBox[{"Quotient", "[", 
                 RowBox[{"oidx", ",", "k0"}], "]"}]}]}], ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", "s0", ",", "1", ",", 
                RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"st", "<", "0"}], "||", 
             RowBox[{"st", ">=", "s0"}]}], ",", 
            RowBox[{"st", "=", "0"}]}], "]"}], ";", "\[IndentingNewLine]", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"BFS", " ", 
            RowBox[{"renumbering", ":", " ", 
             RowBox[{"store", " ", 
              RowBox[{"(", 
               RowBox[{"id", "+", "1"}], ")"}], " ", "in", " ", "map", " ", 
              "so", " ", "0", " ", "means", " ", "\"\<unseen\>\""}]}]}], 
           "*)"}], "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"map", "[", 
            RowBox[{"[", 
             RowBox[{"st", "+", "1"}], "]"}], "]"}], "=", "0"}], ";", 
          RowBox[{
           RowBox[{"q", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "=", "st"}], ";", 
          "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"While", "[", 
           RowBox[{
            RowBox[{"h", "<=", "t"}], ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"u", "=", 
              RowBox[{"q", "[", 
               RowBox[{"[", "h", "]"}], "]"}]}], ";", 
             RowBox[{"h", "++"}], ";", "\[IndentingNewLine]", 
             RowBox[{"Do", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{
                RowBox[{"v", "=", 
                 RowBox[{"tab", "[", 
                  RowBox[{"[", 
                   RowBox[{
                    RowBox[{"u", "*", "k0"}], "+", "m", "+", "1"}], "]"}], 
                  "]"}]}], ";", "\[IndentingNewLine]", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"map", "[", 
                    RowBox[{"[", 
                    RowBox[{"v", "+", "1"}], "]"}], "]"}], "<", "0"}], ",", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"map", "[", 
                    RowBox[{"[", 
                    RowBox[{"v", "+", "1"}], "]"}], "]"}], "=", "next"}], ";", 
                   RowBox[{"next", "++"}], ";", 
                   RowBox[{"t", "++"}], ";", 
                   RowBox[{
                    RowBox[{"q", "[", 
                    RowBox[{"[", "t", "]"}], "]"}], "=", "v"}]}]}], "]"}], 
                ";"}], ",", "\[IndentingNewLine]", 
               RowBox[{"{", 
                RowBox[{"m", ",", "0", ",", 
                 RowBox[{"k0", "-", "1"}]}], "}"}]}], "\[IndentingNewLine]", 
              "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Number", " ", "of", " ", "states", " ", "reached", " ", "by", " ",
             "BFS", " ", "from", " ", "st0"}], "*)"}], "\[IndentingNewLine]", 
          
          RowBox[{"len", "=", "t"}], ";", "\[IndentingNewLine]", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Actions", " ", "in", " ", "canonical", " ", 
            RowBox[{"(", "BFS", ")"}], " ", "order"}], "*)"}], 
          "\[IndentingNewLine]", 
          RowBox[{"Do", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"u", "=", 
              RowBox[{"q", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}], ";", 
             RowBox[{
              RowBox[{"key", "[", 
               RowBox[{"[", "p", "]"}], "]"}], "=", 
              RowBox[{"out", "[", 
               RowBox[{"[", 
                RowBox[{"u", "+", "1"}], "]"}], "]"}]}], ";", 
             RowBox[{"p", "++"}], ";"}], ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", "1", ",", "len"}], "}"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "transition", " ", "targets", " ", "in", " ", "canonical", " ", 
            "order"}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{"Do", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"u", "=", 
              RowBox[{"q", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}], ";", 
             RowBox[{"Do", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"v", "=", 
                 RowBox[{"tab", "[", 
                  RowBox[{"[", 
                   RowBox[{
                    RowBox[{"u", "*", "k0"}], "+", "m", "+", "1"}], "]"}], 
                  "]"}]}], ";", 
                RowBox[{
                 RowBox[{"key", "[", 
                  RowBox[{"[", "p", "]"}], "]"}], "=", 
                 RowBox[{"map", "[", 
                  RowBox[{"[", 
                   RowBox[{"v", "+", "1"}], "]"}], "]"}]}], ";", 
                RowBox[{"p", "++"}], ";"}], ",", 
               RowBox[{"{", 
                RowBox[{"m", ",", "0", ",", 
                 RowBox[{"k0", "-", "1"}]}], "}"}]}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", "1", ",", "len"}], "}"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Take", "[", 
           RowBox[{"key", ",", 
            RowBox[{"len", 
             RowBox[{"(", 
              RowBox[{"k0", "+", "1"}], ")"}]}]}], "]"}]}]}], 
        "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"CompilationTarget", "->", "\"\<C\>\""}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"RuntimeOptions", "->", "\"\<Speed\>\""}]}], 
      "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
    "]"}]}]}]}], "Input",

        RowBox[{"k", "^", "s"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nxt", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"s", "==", "1"}], ",", 

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "IterateTournament", "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "IterateTournament", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{"\"\<ReturnHaltingFlags\>\"", "->", "False"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"IterateTournament", "[", 
   RowBox[{"strat_", ",", "rules_", ",", 
    RowBox[{"best_", ":", 
     RowBox[{"UpTo", "[", "3", "]"}]}], ",", 
    RowBox[{"game_", ":", "$PrisonersDilemma"}], ",", 
    RowBox[{"gamesteps_", ":", "10"}], ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"GenerateBlockSequence", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Normal", "[", 
      RowBox[{"TakeLargestBy", "[", 
       RowBox[{
        RowBox[{"TournamentScoreboard", "[", 
         RowBox[{"TournamentScores", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"strat", "[", "#Rule", "]"}], "&"}], ",", 
           RowBox[{"Tuples", "[", 
            RowBox[{
             RowBox[{"MapIndexed", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"<|", 
                 RowBox[{
                  RowBox[{"\"\<ID\>\"", "->", 
                   RowBox[{"First", "[", "#2", "]"}]}], ",", 
                  RowBox[{"\"\<Rule\>\"", "->", "#1"}]}], "|>"}], "&"}], ",", 
               "rules"}], "]"}], ",", "2"}], "]"}], ",", "game", ",", 
           "gamesteps", ",", 
           RowBox[{"\"\<Parallel\>\"", "->", "False"}], ",", 
           RowBox[{"\"\<ReturnHaltingFlags\>\"", "->", 
            RowBox[{
            "OptionValue", "[", "\"\<ReturnHaltingFlags\>\"", "]"}]}]}], 
          "]"}], "]"}], ",", 
        RowBox[{"#TotalPayoff", "&"}], ",", "best"}], "]"}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2", ",", "\"\<Rule\>\""}], "]"}], "]"}], ",", 
    RowBox[{"Length", "[", "rules", "]"}]}], "]"}]}]}], "Input",

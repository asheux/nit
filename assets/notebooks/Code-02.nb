Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "MarginScalingExponent", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "MarginScalingExponent", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<YMin\>\"", "->", "0"}], ",", 
     RowBox[{"\"\<Method\>\"", "->", "Automatic"}], ",", 
     RowBox[{"\"\<MinRepeats\>\"", "->", "3"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MarginScalingExponent", "[", 
   RowBox[{"series_List", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "t", ",", "y", ",", "fit", ",", "cyc", ",", "tr", ",", "idxall", ",", 
      "minpts", ",", "idx", ",", 
      RowBox[{"n", "=", 
       RowBox[{"Length", "[", "series", "]"}]}], ",", 
      RowBox[{"ymin", "=", 
       RowBox[{"OptionValue", "[", "\"\<YMin\>\"", "]"}]}], ",", 
      RowBox[{"method", "=", 
       RowBox[{"OptionValue", "[", "\"\<Method\>\"", "]"}]}], ",", 
      RowBox[{"minrep", "=", 
       RowBox[{"OptionValue", "[", "\"\<MinRepeats\>\"", "]"}]}]}], "}"}], ",",
     "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"method", "===", "\"\<CycleDrift\>\""}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"tr", ",", "cyc"}], "}"}], "=", 
        RowBox[{"FindTransientRepeat", "[", 
         RowBox[{
          RowBox[{"Differences", "[", 
           RowBox[{"Prepend", "[", 
            RowBox[{"series", ",", "0"}], "]"}], "]"}], ",", "minrep"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Total", "[", "cyc", "]"}], "==", "0"}], ",", "0", ",", 
         "1"}], "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"t", "=", 
        RowBox[{"Range", "[", "n", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"y", "=", 
        RowBox[{"Abs", "[", "series", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"idxall", "=", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"Range", "[", "n", "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"y", "[", 
             RowBox[{"[", "#", "]"}], "]"}], ">", "ymin"}], "&"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"minpts", "=", 
        RowBox[{"Min", "[", 
         RowBox[{
          RowBox[{"Max", "[", 
           RowBox[{"20", ",", 
            RowBox[{"Ceiling", "[", 
             RowBox[{"0.2", 
              RowBox[{"Length", "[", "idxall", "]"}]}], "]"}]}], "]"}], ",", 
          RowBox[{"Length", "[", "idxall", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"idx", "=", 
        RowBox[{"idxall", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"Max", "[", 
            RowBox[{"1", ",", 
             RowBox[{
              RowBox[{"Floor", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"1", "-", "0.5"}], ")"}], 
                RowBox[{"Length", "[", "idxall", "]"}]}], "]"}], "+", "1"}]}],
             "]"}], ";;"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"fit", "=", 
        RowBox[{"FindFit", "[", 
         RowBox[{
          RowBox[{"Transpose", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Log", "[", "idx", "]"}], ",", 
             RowBox[{"Log", "[", 
              RowBox[{"y", "[", 
               RowBox[{"[", "idx", "]"}], "]"}], "]"}]}], "}"}], "]"}], ",", 
          RowBox[{"a", "+", 
           RowBox[{"b", " ", "x"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"a", ",", "b"}], "}"}], ",", "x"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"b", "/.", "fit"}]}]}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]}], "Input",

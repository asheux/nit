Cell[BoxData[{
 RowBox[{"ClearAll", "[", "MoveTreeGraph2DScored", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "MoveTreeGraph2DScored", "]"}], " ", "=", " ", 
   RowBox[{"{", 
